# ============================================
# RENDER DEPLOYMENT - ENVIRONMENT VARIABLES
# ============================================
# Copy this to your Render dashboard for each service

# ============== BACKEND SERVICE ==============

# API Keys
GROQ_API_KEY=your_groq_api_key_here

# Email Configuration (Gmail with App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password

# MongoDB (Set automatically by Render Private Service)
MONGO_URL=mongodb+srv://username:password@host/database?retryWrites=true&w=majority
DB_NAME=ai_sales_db

# CRM Integration (Salesforce)
USE_CRM=true
SF_USERNAME=your_salesforce_email@company.com
SF_PASSWORD=your_salesforce_password
SF_TOKEN=your_salesforce_security_token

# Frontend URL (for CORS)
FRONTEND_URL=https://sales-crm-frontend.onrender.com

# ============== FRONTEND SERVICE ==============

VITE_API_URL=https://sales-crm-api.onrender.com

# ============================================
# HOW TO ADD ENVIRONMENT VARIABLES IN RENDER:
# ============================================
# 1. Go to your service dashboard
# 2. Click "Environment" tab
# 3. Click "Add Environment Variable"
# 4. Paste each key=value pair
# 5. Services redeploy automatically
